rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // helper function
    function isAuthenticated() {
      return request.auth != null && request.auth.uid != null;
    }

    function ngoIdByCard(cardId) {
      return get(/databases/$(database)/documents/problem_cards/$(cardId)).data.ngoId;
    }

    function ngoIdByTask(taskId) {
      return ngoIdByCard(get(/databases/$(database)/documents/tasks/$(taskId)).data.problemCardId);
    }

    function isTaskNgoOwner() {
      return isAuthenticated() && request.auth.uid == ngoIdByCard(resource.data.problemCardId);
    }

    function isTaskNgoOwnerOnCreate() {
      return isAuthenticated() && request.auth.uid == ngoIdByCard(request.resource.data.problemCardId);
    }

    function isVolunteerSelfClaim() {
      return isAuthenticated() &&
        request.resource.data.diff(resource.data).changedKeys().hasOnly(['assignedVolunteerIds']) &&
        request.resource.data.assignedVolunteerIds.hasAll(resource.data.assignedVolunteerIds) &&
        request.resource.data.assignedVolunteerIds.size() <= resource.data.assignedVolunteerIds.size() + 1 &&
        request.auth.uid in request.resource.data.assignedVolunteerIds;
    }

    function isVolunteerProofSubmit() {
      return isAuthenticated() &&
        request.auth.uid in resource.data.assignedVolunteerIds &&
        request.resource.data.diff(resource.data).changedKeys().hasOnly(['isProofSubmitted']) &&
        resource.data.isProofSubmitted == false &&
        request.resource.data.isProofSubmitted == true;
    }

    function isNgoForMatch() {
      return isAuthenticated() && request.auth.uid == ngoIdByTask(resource.data.taskId);
    }

    function isVolunteerForMatch() {
      return isAuthenticated() && request.auth.uid == resource.data.volunteerId;
    }

    match /users/{userId} {
      // Basic rule for the user schema we created earlier
      allow read: if isAuthenticated();
      allow write: if isAuthenticated() && request.auth.uid == userId;
    }

    match /problem_cards/{cardId} {
      allow read: if isAuthenticated();
      allow update, delete: if isAuthenticated() && request.auth.uid == resource.data.ngoId;
      allow create: if isAuthenticated() && request.auth.uid == request.resource.data.ngoId;
    }

    match /tasks/{taskId} {
      allow read: if isAuthenticated();
      allow create: if isTaskNgoOwnerOnCreate();
      allow update: if isTaskNgoOwner() || isVolunteerSelfClaim() || isVolunteerProofSubmit();
      allow delete: if isTaskNgoOwner();
    }
    match /ngo_profiles/{profileId} {
      allow read, update, delete: if isAuthenticated();
      allow create: if isAuthenticated() && request.auth.uid == request.resource.data.id;
    }
    match /volunteer_profiles/{profileId} {
      allow read: if isAuthenticated();
      allow update, delete: if isAuthenticated() && request.auth.uid == profileId;
      allow create: if isAuthenticated() && request.auth.uid == request.resource.data.uid;
    }

    match /match_records/{matchId} {
      allow read: if isVolunteerForMatch() || isNgoForMatch();
      allow create: if isAuthenticated() && request.auth.uid == request.resource.data.volunteerId;
      allow update: if isVolunteerForMatch() || isNgoForMatch();
      allow delete: if isNgoForMatch();
    }
    
    match /raw_uploads/{uploadId} {
      allow read, update, delete: if isAuthenticated() && request.auth.uid == resource.data.ngoId;
      allow create: if isAuthenticated() && request.auth.uid == request.resource.data.ngoId;
    }

    match /volunteer_notifications/{notificationId} {
      allow read, update, delete: if isAuthenticated() && request.auth.uid == resource.data.volunteerId;
      allow create: if isAuthenticated() && request.auth.uid == request.resource.data.volunteerId;
    }

    match /ngo_notifications/{notificationId} {
      allow read, update, delete: if isAuthenticated() && request.auth.uid == resource.data.ngoId;
      allow create: if isAuthenticated() && request.auth.uid == request.resource.data.ngoId;
    }

    match /task_chats/{taskId} {
      match /messages/{messageId} {
        allow read, create: if isAuthenticated() && (
          request.auth.uid in get(/databases/$(database)/documents/tasks/$(taskId)).data.assignedVolunteerIds ||
          request.auth.uid == ngoIdByTask(taskId)
        );
      }
    }
  }
}
